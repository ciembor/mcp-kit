{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "mutate": [
    "packages/*/src/**/*.ts",
    "!packages/*/src/**/*.test.ts",
    "!packages/*/src/**/index.ts",
    "!packages/*/src/bin.ts",
    "!packages/*/src/generated/**"
  ],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 80
  },
  "reporters": ["html", "clear-text", "progress"]
}
