{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "smells": "eslint --config eslint.smells.config.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "quality": "mcp-kit quality --full",
    "quality:fast": "mcp-kit quality --fast",
    "quality:full": "mcp-kit quality --full",
    "doctor": "mcp-kit doctor"
  },
  "dependencies": {
    "@mcp-kit/core": "{{MCP_KIT_CORE}}",
    "@mcp-kit/node": "{{MCP_KIT_NODE}}",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@mcp-kit/cli": "{{MCP_KIT_CLI}}",
    "@mcp-kit/testing": "{{MCP_KIT_TESTING}}",
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "4.1.8",
    "@types/node": "25.9.2",
    "dependency-cruiser": "17.4.3",
    "eslint": "10.4.1",
    "eslint-plugin-sonarjs": "4.0.3",
    "knip": "6.16.1",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
