{
  "name": "@mcp-kit/cli",
  "version": "0.0.0",
  "description": "Command-line tooling for mcp-kit projects.",
  "type": "module",
  "bin": {
    "mcp-kit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --sourcemap --clean && rm -rf dist/template && node ../../scripts/prepare-bundled-template.mjs ../../templates/default dist/template",
    "clean": "rm -rf dist",
    "typecheck": "tsc --project tsconfig.json"
  },
  "engines": {
    "node": "^22.13.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
